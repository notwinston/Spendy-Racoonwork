{
  "expo": {
    "name": "FutureSpend",
    "slug": "futurespend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "futurespend",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.futurespend.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A1628",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.futurespend.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "FutureSpend needs access to your photos to scan receipts.",
          "cameraPermission": "FutureSpend needs access to your camera to scan receipts."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "FutureSpend needs access to your calendar to predict spending from upcoming events."
        }
      ]
    ]
  }
}
